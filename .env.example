# Copiar a `.env` en la raíz del monorepo (transversal-ms carga este archivo).

# --- App transversal-ms ---
TRANSVERSAL_MS_PORT=8080
APP_ENV=development

# --- AWS: identidad (misma cadena que AWS CLI / SSO) ---
# Opcional: perfil distinto de [default] (tras `aws sso login --profile ...`).
# AWS_PROFILE=tu-perfil
AWS_REGION=us-east-1
# Contra AWS real: NO defina las dos siguientes si usa `~/.aws/credentials` o SSO.
# Solo para claves estáticas o CI (evitar commitear valores reales).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- SQS (transversal-ms) ---
# URLs HTTPS de las colas en AWS (misma región que AWS_REGION / credenciales vigentes).
TRANSVERSAL_SQS_OUTBOUND_QUEUE_URL=
TRANSVERSAL_SQS_INBOUND_QUEUE_URL=
TRANSVERSAL_SQS_UPLOAD_FILES_QUEUE_URL=
TRANSVERSAL_SQS_WAIT_TIME_SECONDS=20
TRANSVERSAL_SQS_MAX_NUMBER_OF_MESSAGES=10
TRANSVERSAL_SQS_VISIBILITY_TIMEOUT_SECONDS=30
TRANSVERSAL_SQS_DELETE_ON_VALIDATION_ERROR=false

# --- S3 (almacenamiento de archivos) ---
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
# Opcional: claves explícitas (mismo efecto que AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY si faltan).
# Sin claves en env, S3Client usa la cadena por defecto del SDK (variables estándar, perfil, SSO, etc.).
# AWS_S3_ACCESS_KEY_ID=
# AWS_S3_SECRET_ACCESS_KEY=
# AWS_S3_SESSION_TOKEN=
# Prefijo público opcional para URLs en eventos (sin firmar).
# AWS_S3_PUBLIC_BASE_URL=
# LocalStack:
# AWS_S3_ENDPOINT=http://127.0.0.1:4566
# AWS_S3_FORCE_PATH_STYLE=true

# --- Amazon Cognito (sin valores por defecto en código; definir en despliegue) ---
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

MFA_ISSUER=Platam Pay

# --- Otros ---
RUES_API_BASE_URL=

# --- Base de datos (ajustar según su entorno) ---
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USERNAME=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=
# TYPEORM_SYNC=false

# --- contracts-ms (HTTP + SQS) ---
# CONTRACTS_MS_PORT=8084
# CONTRACTS_SQS_OUTBOUND_QUEUE_URL=
# CONTRACTS_SQS_CREATE_CONTRACT_QUEUE_URL=
# CONTRACTS_SQS_GET_CONTRACT_QUEUE_URL=
# CONTRACTS_SQS_WAIT_TIME_SECONDS=20
# CONTRACTS_SQS_MAX_NUMBER_OF_MESSAGES=10
# CONTRACTS_SQS_VISIBILITY_TIMEOUT_SECONDS=30
# CONTRACTS_SQS_DELETE_ON_VALIDATION_ERROR=false

# --- notifications-ms (HTTP + SQS + Resend + Twilio) ---
# NOTIFICATIONS_MS_PORT=8085
# NOTIFICATIONS_SQS_OUTBOUND_QUEUE_URL=
# NOTIFICATIONS_SQS_INBOUND_QUEUE_URL=
# LocalStack (misma región que AWS_REGION):
# AWS_SQS_ENDPOINT=http://127.0.0.1:4566
# NOTIFICATIONS_SQS_INBOUND_QUEUE_URL=http://127.0.0.1:4566/000000000000/notifications-inbound
# NOTIFICATIONS_SQS_WAIT_TIME_SECONDS=20
# NOTIFICATIONS_SQS_MAX_NUMBER_OF_MESSAGES=10
# NOTIFICATIONS_SQS_VISIBILITY_TIMEOUT_SECONDS=30
# NOTIFICATIONS_SQS_DELETE_ON_VALIDATION_ERROR=false
# RESEND_API_KEY=
# NOTIFICATIONS_EMAIL_FROM=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_SMS=
# TWILIO_FROM_WHATSAPP=

# --- ZapSign (contracts-ms: POST /contracts/with-zapsign y webhooks) ---
# ZAPSIGN_BASE_URL=https://api.zapsign.com.br
# ZAPSIGN_API_TOKEN=
# ZAPSIGN_SANDBOX_DEFAULT=true
# ZAPSIGN_FOLDER_PATH_DEFAULT=/
# Opcional: si se define, el webhook debe enviar header X-Zapsign-Webhook-Secret con el mismo valor
# ZAPSIGN_WEBHOOK_SECRET=
