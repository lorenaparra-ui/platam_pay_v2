%% Flujos de negocio de alto nivel (alineado a MS + dominios en libs/)
%% Actualizado: 2026-04-13

flowchart TB
    subgraph Transversal["transversal-ms + transversal-data"]
        T1["Usuarios / roles / permisos"]
        T2["Personas / ciudades / divisas"]
        T3["Catálogos de estado transversal"]
        T4["Auditoría / parámetros globales"]
    end

    subgraph Suppliers["suppliers-ms + suppliers-data"]
        S1["Negocios / proveedores / socios"]
        S2["Cuentas bancarias / órdenes de compra"]
        S3["Onboarding partner — saga"]
        S4["Asesores comerciales"]
    end

    subgraph Products["products-ms + products-data"]
        P1["Solicitudes de crédito — credit_applications"]
        P2["Facilidades / categorías — assignments"]
        P3["Contratos / plantillas / documentos"]
        P4["Consultas Experian / SARLAFT / web / IA"]
        P5["Solicitudes de desembolso — loan_requests"]
    end

    subgraph Contracts["contracts-ms"]
        C1["Firma electrónica — integración plantillas"]
    end

    subgraph DisbursementColl["disbursement-data + collections-data"]
        D1["Lotes y desembolsos"]
        D2["Préstamos — loans mínimo hoy"]
        D3["Pagos y aplicaciones"]
        D4["Reglas de fee de cobranza"]
    end

    T2 --> S1
    S1 --> S3
    S3 --> P2
    T1 --> S4
    S4 --> P1
    P1 --> P3
    P3 --> C1
    C1 --> P2
    P5 --> D1
    D1 --> D2
    D2 --> D3
    D3 --> D4
