%% ERD — PLATAM PAY v2 | Alineado a entidades TypeORM en libs/*-data
%% Orquestación: database/src/data-source.ts → ALL_DATA_ENTITIES
%% Actualizado: 2026-04-13
%%
%% Schemas PostgreSQL: transversal_schema | suppliers_schema | products_schema
%%                    | disbursement_schema | collections_schema
%%
%% Convención en notas: [T] transversal | [S] suppliers | [P] products | [D] disbursement | [C] collections

erDiagram

  %% ──────────────────────────────────────────────
  %% transversal_schema
  %% ──────────────────────────────────────────────

  catalog_status_types {
    bigint  id           PK
    uuid    external_id UK
    varchar entity_type "NOT NULL"
    varchar code         "NOT NULL"
    varchar display_name
    boolean is_active
    tstz    created_at
    tstz    updated_at
  }

  roles {
    bigint  id          PK
    uuid    external_id UK
    varchar name        UK
    text    description
    tstz    created_at
    tstz    updated_at
  }

  permissions {
    bigint  id          PK
    uuid    external_id UK
    varchar code        UK
    text    description
    tstz    created_at
    tstz    updated_at
  }

  role_permissions {
    bigint  id             PK
    uuid    external_id    UK
    bigint  role_id        FK
    bigint  permission_id  FK
    tstz    created_at
    tstz    updated_at
  }

  currencies {
    bigint  id              PK
    uuid    external_id     UK
    varchar code            UK
    varchar name
    varchar symbol
    int     decimal_places
    boolean is_active
    tstz    created_at
    tstz    updated_at
  }

  cities {
    bigint  id            PK
    uuid    external_id   UK
    varchar country_name
    varchar country_code
    varchar state_name
    varchar city_name
    bigint  currency_id   FK
    tstz    created_at
    tstz    updated_at
  }

  users {
    bigint  id            PK
    uuid    external_id   UK
    uuid    cognito_sub   UK
    varchar email         UK
    bigint  role_id       FK
    bigint  parent_id     FK "jerarquía opcional"
    varchar state         "ENUM user_state"
    bigint  person_id     FK
    tstz    last_login_at
    tstz    created_at
    tstz    updated_at
  }

  persons {
    bigint  id           PK
    uuid    external_id  UK
    varchar country_code
    varchar first_name
    varchar last_name
    varchar doc_type
    varchar doc_number   UK
    bigint  city_id      FK
    varchar state        "ENUM person record"
    tstz    created_at
    tstz    updated_at
  }

  global_params {
    bigint  id          PK
    uuid    external_id UK
    varchar code        "UQ con valid_from"
    jsonb   value
    date    valid_from
    bigint  created_by  FK "users"
    tstz    created_at
  }

  audit_logs {
    bigint  id          PK
    uuid    external_id UK
    varchar entity_type "ENUM audit_log_entity_type"
    bigint  entity_id
    varchar action       "ENUM audit_log_action_type"
    jsonb   old_value
    jsonb   new_value
    bigint  performed_by FK "users"
    tstz    performed_at
  }

  upload_files_idempotency {
    bigint id PK
    uuid   correlation_id
    varchar status
    tstz   created_at
  }

  partner_create_user_sqs_idempotency {
    bigint id PK
    uuid   message_id UK
    tstz   created_at
  }

  %% ──────────────────────────────────────────────
  %% suppliers_schema
  %% ──────────────────────────────────────────────

  business_seniority {
    bigint  id          PK
    uuid    external_id UK
    varchar description
    int     range_start
    int     range_end
    tstz    created_at
    tstz    updated_at
  }

  businesses {
    bigint  id                    PK
    uuid    external_id           UK
    bigint  person_id             FK
    bigint  business_seniority_id FK
    bigint  city_id               FK
    varchar entity_type
    varchar tax_id                UK
    varchar state                 "ENUM business lifecycle"
    tstz    created_at
    tstz    updated_at
  }

  legal_representatives {
    bigint  id          PK
    uuid    external_id UK
    bigint  person_id   FK
    boolean is_primary
    tstz    created_at
    tstz    updated_at
  }

  bank_accounts {
    bigint  id          PK
    uuid    external_id UK
    varchar bank_entity
    varchar account_number
    varchar state       "ENUM bank account"
    tstz    created_at
    tstz    updated_at
  }

  suppliers {
    bigint  id                       PK
    uuid    external_id               UK
    bigint  business_id               FK "UNIQUE 1:1"
    bigint  legal_representative_id   FK
    bigint  bank_account_id           FK "UNIQUE 1:1"
    varchar state                     "ENUM supplier"
    tstz    created_at
    tstz    updated_at
  }

  partners {
    bigint  id          PK
    uuid    external_id UK
    bigint  supplier_id FK "UNIQUE 1:1"
    varchar state       "ENUM partner"
    tstz    created_at
    tstz    updated_at
  }

  sales_representatives {
    bigint  id          PK
    uuid    external_id UK
    bigint  partner_id  FK
    bigint  user_id     FK
    varchar state       "ENUM sales_representative_state"
    tstz    created_at
    tstz    updated_at
  }

  shareholders {
    bigint  id          PK
    uuid    external_id UK
    bigint  business_id FK
    tstz    created_at
    tstz    updated_at
  }

  purchase_orders {
    bigint   id           PK
    uuid     external_id  UK
    varchar  external_user_id "sin FK bigint"
    bigint   supplier_id  FK
    decimal  amount
    tstz     created_at
    tstz     updated_at
  }

  partner_onboarding_sagas {
    bigint    id           PK
    uuid      external_id  UK
    uuid      correlation_id
    varchar   status       "RUNNING|COMPLETED|..."
    smallint  current_step
    tstz      created_at
    tstz      updated_at
  }

  %% ──────────────────────────────────────────────
  %% products_schema
  %% ──────────────────────────────────────────────

  contract_templates {
    bigint  id          PK
    uuid    external_id UK
    varchar name
    text    description
    text    template_url "S3"
    varchar version
    varchar state       "ENUM ContractTemplateCatalogStatus"
    tstz    created_at
    tstz    updated_at
  }

  contracts {
    bigint  id                   PK
    uuid    external_id          UK
    bigint  user_id               "bigint nullable"
    bigint  contract_template_id  FK
    varchar zapsign_token         UK
    varchar state                 "ENUM contract_catalog_status"
    text    original_file_url
    text    signed_file_url
    jsonb   form_answers_json
    tstz    created_at
    tstz    updated_at
  }

  credit_facilities {
    bigint   id          PK
    uuid     external_id UK
    bigint   contract_id FK "OneToOne opcional"
    bigint   business_id  FK
    varchar  state       "ENUM credit_facility_state"
    decimal  total_limit
    tstz     created_at
    tstz     updated_at
  }

  client_category_assignments {
    bigint credit_facility_id FK
    bigint category_id        FK
  }

  categories {
    bigint   id          PK
    uuid     external_id UK
    bigint   partner_id  FK "nullable SET NULL"
    varchar  name
    varchar  modality    "ENUM loan_request_modality"
    varchar  state       "ENUM category"
    decimal  interest_rate
    tstz     created_at
    tstz     updated_at
  }

  credit_applications {
    bigint   id                      PK
    uuid     external_id             UK
    bigint   person_id               FK
    bigint   partner_id              FK
    bigint   partner_category_id    FK
    bigint   business_id             FK
    bigint   sales_representative_id FK
    varchar  status                  "ENUM credit_application_status nativo PG"
    bigint   requested_credit_line   "centavos"
    tstz     submission_date
    tstz     created_at
    tstz     updated_at
  }

  documents {
    bigint id PK
    uuid   external_id UK
    bigint credit_application_id FK
    varchar verification_status "ENUM"
    tstz   created_at
  }

  loan_requests {
    bigint id PK
    uuid   external_id UK
    varchar status "ENUM loan_request_status"
    tstz   created_at
  }

  experian_queries {
    bigint id PK
    uuid   external_id UK
    varchar status
    tstz   created_at
  }

  sarlaft_checks {
    bigint id PK
    uuid   external_id UK
    varchar status
    tstz   created_at
  }

  web_queries {
    bigint id PK
    uuid   external_id UK
    tstz   created_at
  }

  ai_agent_analyses {
    bigint id PK
    uuid   external_id UK
    tstz   created_at
  }

  usura_rates {
    bigint id PK
    uuid   external_id UK
    decimal rate
    date   valid_from
    tstz   created_at
  }

  %% ──────────────────────────────────────────────
  %% disbursement_schema
  %% ──────────────────────────────────────────────

  loans {
    bigint id          PK
    uuid   external_id UK
    tstz   created_at
    tstz   updated_at
  }

  disbursement_batches {
    bigint id          PK
    uuid   external_id UK
    varchar status "ENUM disbursement_batches_status"
    tstz   created_at
    tstz   updated_at
  }

  disbursements {
    bigint id          PK
    uuid   external_id UK
    bigint loan_id
    bigint loan_request_id
    bigint partner_id
    bigint supplier_id
    bigint bank_account_id
    bigint batch_id FK
    varchar disbursement_type "ENUM"
    varchar status          "ENUM disbursement_status"
    decimal amount
    tstz   created_at
    tstz   updated_at
  }

  payments {
    bigint id          PK
    uuid   external_id UK
    tstz   created_at
    tstz   updated_at
  }

  payment_allocations {
    bigint id PK
    uuid   external_id UK
    bigint payment_id FK
    bigint loan_id    FK
  }

  adjustments {
    bigint id PK
    uuid   external_id UK
    bigint loan_id FK
    bigint partner_id FK
    bigint disbursement_batch_id FK
    varchar status "ENUM adjustments_status"
    tstz   created_at
    tstz   updated_at
  }

  accruals {
    bigint id PK
    bigint loan_id FK
    date   calculation_date
    decimal balance_principal_overdue
  }

  %% ──────────────────────────────────────────────
  %% collections_schema
  %% ──────────────────────────────────────────────

  collection_fee_rules {
    bigint id PK
    uuid   external_id UK
    int    days_overdue
    decimal fee_rate
    date   valid_from
    bigint created_by FK "users"
    tstz   created_at
  }

  %% ──────────────────────────────────────────────
  %% Relaciones principales
  %% ──────────────────────────────────────────────

  roles            ||--o{ role_permissions      : ""
  permissions      ||--o{ role_permissions      : ""
  roles            ||--o{ users                 : ""
  currencies       ||--o{ cities                : ""
  cities           ||--o{ persons               : ""
  persons          ||--o| users                 : "person_id"
  users            ||--o{ users                 : "parent_id"
  users            ||--o{ audit_logs           : "performed_by"
  users            ||--o{ global_params        : "created_by"

  persons          ||--o{ businesses            : ""
  cities           ||--o{ businesses            : ""
  business_seniority ||--o{ businesses          : ""
  businesses       ||--o{ shareholders          : ""

  persons          ||--o{ legal_representatives : ""
  businesses       ||--|| suppliers             : ""
  legal_representatives ||--o{ suppliers        : ""
  bank_accounts    ||--|| suppliers             : ""
  suppliers        ||--|| partners              : ""
  partners         ||--o{ sales_representatives : ""
  users            ||--|| sales_representatives : "user_id"
  suppliers        ||--o{ purchase_orders      : ""

  contract_templates ||--o{ contracts           : ""
  contracts        ||--o| credit_facilities     : "contract_id"
  businesses       ||--o{ credit_facilities     : ""
  credit_facilities ||--o{ client_category_assignments : ""
  categories       ||--o{ client_category_assignments : ""
  partners         ||--o{ categories            : ""

  partners         ||--o{ credit_applications   : ""
  persons          ||--o{ credit_applications   : ""
  businesses       ||--o{ credit_applications   : ""
  categories       ||--o{ credit_applications   : "partner_category_id"
  sales_representatives ||--o{ credit_applications : ""

  credit_applications ||--o{ documents          : ""

  disbursement_batches ||--o{ disbursements    : ""
  loans                ||--o{ disbursements     : "loan_id opcional"
  loans                ||--o{ accruals          : ""
  loans                ||--o{ adjustments       : ""
  partners             ||--o{ adjustments       : ""
  disbursement_batches ||--o{ adjustments       : ""

  payments             ||--o{ payment_allocations : ""
  loans                ||--o{ payment_allocations : ""

  users                ||--o{ collection_fee_rules : "created_by"
