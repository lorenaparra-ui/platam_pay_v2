-- =============================================================================
-- PLATAM PAY v2 — Restructured & Merged Schema DDL
-- Auditoría y reestructuración: credit_applications_bnpl → credit_facilities
--                                partners → suppliers
-- Autor: Senior Data Architect Audit
-- Fecha: 2025
-- Motor: PostgreSQL 15+
-- =============================================================================

-- ---------------------------------------------------------------------------
-- NOTA DE MIGRACIÓN
-- credit_applications_bnpl  →  credit_facilities  (tabla central de crédito)
-- partners                  →  suppliers          (proveedores / socios)
-- partner_categories        →  supplier_categories
-- ---------------------------------------------------------------------------


-- =============================================================================
-- BLOQUE 0: EXTENSIONES REQUERIDAS
-- =============================================================================
CREATE EXTENSION IF NOT EXISTS "pgcrypto";   -- gen_random_uuid()
CREATE EXTENSION IF NOT EXISTS "btree_gin";  -- índices compuestos GIN


-- =============================================================================
-- BLOQUE 1: CATÁLOGOS BASE
-- =============================================================================

-- -----------------------------------------------------------------------------
-- 1.1  statuses  —  Catálogo centralizado de estados por entidad
-- -----------------------------------------------------------------------------
CREATE TABLE statuses (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    entity_type     VARCHAR(100)    NOT NULL,
    code            VARCHAR(50)     NOT NULL,
    display_name    VARCHAR(100)    NOT NULL,
    description     TEXT,
    is_active       BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),

    CONSTRAINT uq_statuses_entity_code UNIQUE (entity_type, code)
);

CREATE INDEX idx_statuses_entity_type ON statuses (entity_type);

COMMENT ON TABLE statuses IS 'Catálogo maestro de estados. Reemplaza enums dispersos en cada tabla.';
COMMENT ON COLUMN statuses.entity_type IS 'Nombre de la entidad dueña: credit_facilities, suppliers, loans, etc.';


-- -----------------------------------------------------------------------------
-- 1.2  options  —  Catálogo de opciones configurables (antes enums hardcoded)
-- -----------------------------------------------------------------------------
CREATE TABLE options (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    option_group    VARCHAR(100)    NOT NULL,
    code            VARCHAR(80)     NOT NULL,
    display_name    VARCHAR(150)    NOT NULL,
    description     TEXT,
    sort_order      INT             NOT NULL DEFAULT 0,
    is_active       BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),

    CONSTRAINT uq_options_group_code UNIQUE (option_group, code)
);

CREATE INDEX idx_options_group ON options (option_group);

COMMENT ON TABLE options IS 'Catálogo de opciones agrupadas. Ejemplo: option_group=business_seniority.';


-- =============================================================================
-- BLOQUE 2: IDENTIDAD Y AUTENTICACIÓN
-- =============================================================================

-- -----------------------------------------------------------------------------
-- 2.1  roles  (debe crearse antes de users por FK)
-- -----------------------------------------------------------------------------
CREATE TABLE roles (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    name            VARCHAR(80)     NOT NULL UNIQUE,
    description     TEXT,
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);

COMMENT ON TABLE roles IS 'Roles RBAC: admin, analyst, sales_rep, supplier_user, etc.';


-- -----------------------------------------------------------------------------
-- 2.2  permissions
-- -----------------------------------------------------------------------------
CREATE TABLE permissions (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    code            VARCHAR(120)    NOT NULL UNIQUE,
    description     TEXT,
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);


-- -----------------------------------------------------------------------------
-- 2.3  role_permissions  —  Tabla pivote M:N
-- -----------------------------------------------------------------------------
CREATE TABLE role_permissions (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    role_id         BIGINT          NOT NULL REFERENCES roles(id) ON DELETE CASCADE,
    permission_id   BIGINT          NOT NULL REFERENCES permissions(id) ON DELETE CASCADE,
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),

    CONSTRAINT uq_role_permission UNIQUE (role_id, permission_id)
);

CREATE INDEX idx_role_permissions_role ON role_permissions (role_id);
CREATE INDEX idx_role_permissions_perm ON role_permissions (permission_id);


-- -----------------------------------------------------------------------------
-- 2.4  users
-- -----------------------------------------------------------------------------
CREATE TABLE users (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    cognito_sub     UUID            UNIQUE NOT NULL,
    email           VARCHAR(255)    UNIQUE NOT NULL,
    phone           VARCHAR(30)     UNIQUE,
    role_id         BIGINT          REFERENCES roles(id),
    status_id       BIGINT          NOT NULL REFERENCES statuses(id),
    last_login_at   TIMESTAMPTZ,
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_users_email     ON users (email);
CREATE INDEX idx_users_status    ON users (status_id);
CREATE INDEX idx_users_role      ON users (role_id);

COMMENT ON COLUMN users.status_id IS 'default: pending → active tras aprobación y firma';


-- =============================================================================
-- BLOQUE 3: ENTIDADES GEOGRÁFICAS
-- =============================================================================

CREATE TABLE currencies (
    id                  BIGSERIAL       PRIMARY KEY,
    external_id         UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    code                VARCHAR(3)      NOT NULL UNIQUE,  -- ISO 4217
    name                VARCHAR(120)    NOT NULL,
    symbol              VARCHAR(10),
    decimal_places      INT             NOT NULL DEFAULT 2,
    thousand_separator  VARCHAR(1),
    decimal_separator   VARCHAR(1),
    is_active           BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at          TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at          TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE TABLE cities (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    country_name    VARCHAR(120)    NOT NULL,
    country_code    VARCHAR(2)      NOT NULL
                        CHECK (country_code ~ '^[A-Z]{2}$'),
    state_name      VARCHAR(120)    NOT NULL,
    state_code      VARCHAR(3)
                        CHECK (state_code IS NULL OR state_code ~ '^[A-Z0-9]{2,3}$'),
    city_name       VARCHAR(120)    NOT NULL,
    currency_id     BIGINT          NOT NULL REFERENCES currencies(id),
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),

    CONSTRAINT uq_cities_location UNIQUE (country_code, state_name, city_name)
);

CREATE INDEX idx_cities_country ON cities (country_code);


-- =============================================================================
-- BLOQUE 4: PERSONAS Y NEGOCIOS
-- =============================================================================

-- -----------------------------------------------------------------------------
-- 4.1  persons  —  Personas naturales (PII — requiere cifrado en reposo)
-- -----------------------------------------------------------------------------
CREATE TABLE persons (
    id                  BIGSERIAL       PRIMARY KEY,
    external_id         UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    user_id             BIGINT          NOT NULL REFERENCES users(id),
    country_code        VARCHAR(2),
    first_name          VARCHAR(255)    NOT NULL,  -- PII: cifrar en reposo
    last_name           VARCHAR(255)    NOT NULL,  -- PII: cifrar en reposo
    doc_type            VARCHAR(100)    NOT NULL,
    doc_number          VARCHAR(50)     UNIQUE NOT NULL,  -- PII: cifrar en reposo
    doc_issue_date      DATE,
    birth_date          DATE,                             -- PII: cifrar en reposo
    gender              VARCHAR(20),
    phone               VARCHAR(30),                     -- PII
    residential_address TEXT,                            -- PII
    business_address    TEXT,
    city_id             BIGINT          REFERENCES cities(id),
    created_at          TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at          TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_persons_user   ON persons (user_id);
CREATE INDEX idx_persons_doc    ON persons (doc_number);

COMMENT ON TABLE persons IS 'PII sensible — aplicar cifrado AES-256 en first_name, last_name, doc_number, birth_date, phone, residential_address.';


-- -----------------------------------------------------------------------------
-- 4.2  businesses  —  Negocios PN y empresas PJ (antes companies)
-- -----------------------------------------------------------------------------
CREATE TABLE businesses (
    id                          BIGSERIAL       PRIMARY KEY,
    external_id                 UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    user_id                     BIGINT          NOT NULL REFERENCES users(id),
    city_id                     BIGINT          REFERENCES cities(id),

    -- Discriminador PN / PJ
    entity_type                 VARCHAR(2)      NOT NULL
                                    CHECK (entity_type IN ('PN', 'PJ')),

    -- Campos comunes PN y PJ
    business_name               VARCHAR(255),
    business_address            TEXT,
    business_type               VARCHAR(10),        -- Código CIIU
    relationship_to_business    VARCHAR(100),       -- Único dueño | Socio | Empleado

    -- Campos exclusivos PJ (NULL para PN)
    legal_name                  VARCHAR(255),
    trade_name                  VARCHAR(255),
    tax_id                      VARCHAR(50)     UNIQUE,  -- NIT / RUT — PII
    year_of_establishment       INT,

    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_businesses_user        ON businesses (user_id);
CREATE INDEX idx_businesses_entity_type ON businesses (entity_type);
CREATE INDEX idx_businesses_tax_id      ON businesses (tax_id) WHERE tax_id IS NOT NULL;

COMMENT ON COLUMN businesses.entity_type IS 'PN = Persona Natural, PJ = Persona Jurídica';
COMMENT ON COLUMN businesses.tax_id      IS 'PII — NIT/RUT. Requerido para PJ.';


-- =============================================================================
-- BLOQUE 5: ESTRUCTURA CORPORATIVA Y GARANTES
-- =============================================================================

CREATE TABLE legal_representatives (
    id              BIGSERIAL   PRIMARY KEY,
    external_id     UUID        NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    business_id     BIGINT      NOT NULL REFERENCES businesses(id),
    person_id       BIGINT      NOT NULL REFERENCES persons(id),
    is_primary      BOOLEAN     DEFAULT TRUE,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE TABLE shareholders (
    id                          BIGSERIAL       PRIMARY KEY,
    external_id                 UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    business_id                 BIGINT          NOT NULL REFERENCES businesses(id),
    person_id                   BIGINT          NOT NULL REFERENCES persons(id),
    ownership_percentage        DECIMAL(5,4),
    evaluation_order            INT,
    credit_check_required       BOOLEAN         DEFAULT FALSE,
    credit_check_completed      BOOLEAN         DEFAULT FALSE,
    is_legal_representative     BOOLEAN         DEFAULT FALSE,
    created_at                  TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at                  TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_shareholders_business ON shareholders (business_id);
CREATE INDEX idx_shareholders_person   ON shareholders (person_id);


-- =============================================================================
-- BLOQUE 6: SUPPLIERS (antes: partners)
-- =============================================================================
-- TABLA COMPARATIVA DE FUSIÓN:
--   Schema DBML (partners)          →   Imagen (suppliers)       →   Resultado
--   id bigint                       →   id                       →   id BIGSERIAL PK
--   external_id uuid                →   —                        →   external_id UUID
--   business_id bigint FK           →   —                        →   business_id BIGINT FK → businesses
--   acronym varchar(10)             →   —                        →   acronym VARCHAR(10)
--   logo_url text                   →   —                        →   logo_url TEXT
--   co_branding_logo_url text       →   —                        →   co_branding_logo_url TEXT
--   primary_color varchar(20)       →   —                        →   primary_color VARCHAR(20)
--   secondary_color varchar(20)     →   —                        →   secondary_color VARCHAR(20)
--   light_color varchar(20)         →   —                        →   light_color VARCHAR(20)
--   sales_rep_role_name varchar     →   —                        →   sales_rep_role_name VARCHAR(50)
--   api_key_hash boolean            →   —                        →   api_key_hash BOOLEAN
--   notification_email varchar      →   —                        →   notification_email VARCHAR(255)
--   webhook_url text                →   —                        →   webhook_url TEXT
--   disbursement_notification_email →   —                        →   disbursement_notification_email
--   status_id bigint FK             →   status (varchar)         →   status_id BIGINT FK → statuses ✓ (FK más robusto)
--   —                               →   nit (varchar)            →   tax_id_ref VARCHAR(50) [referencia a businesses.tax_id]
--   —                               →   business_name (varchar)  →   display_name VARCHAR(255) [nombre comercial del supplier]
--   —                               →   bank_account             →   bank_account_number VARCHAR(50)  [NUEVO — PII]
--   —                               →   is_partner (boolean)     →   is_partner BOOLEAN [flag unificado]
--   —                               →   partner_since (nullable) →   partner_since_date DATE
--   —                               →   business_id (nullable)   →   business_id FK (ya existía en schema)
-- =============================================================================

CREATE TABLE suppliers (
    id                              BIGSERIAL       PRIMARY KEY,
    external_id                     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    business_id                     BIGINT          NOT NULL REFERENCES businesses(id),

    -- Datos de identidad del supplier
    display_name                    VARCHAR(255)    NOT NULL,   -- Nombre comercial visible
    acronym                         VARCHAR(10),

    -- Branding / co-branding
    logo_url                        TEXT,
    co_branding_logo_url            TEXT,
    primary_color                   VARCHAR(20),
    secondary_color                 VARCHAR(20),
    light_color                     VARCHAR(20),

    -- Configuración de fuerza de ventas
    sales_rep_role_name             VARCHAR(50)     DEFAULT 'Sales Rep',
    sales_rep_role_name_plural      VARCHAR(50)     DEFAULT 'Sales Reps',
    send_sales_rep_voucher          BOOLEAN         DEFAULT FALSE,

    -- Integración y notificaciones
    api_key_hash                    BOOLEAN         DEFAULT FALSE,  -- TRUE = api key configurada
    notification_email              VARCHAR(255),
    webhook_url                     TEXT,
    disbursement_notification_email VARCHAR(255),

    -- Datos bancarios (PII — requiere cifrado)
    bank_account_number             VARCHAR(100),   -- PII: cifrar en reposo
    bank_account_type               VARCHAR(50),    -- Ahorros | Corriente

    -- Flag partner (de imagen): is_partner=false → solo recibe pagos
    --                            is_partner=true  → accede a credit_facility
    is_partner                      BOOLEAN         NOT NULL DEFAULT FALSE,
    partner_since_date              DATE,           -- Nullable; activo solo si is_partner=true

    -- FK defaults
    default_rep_id                  BIGINT,         -- FK → sales_representatives.id (se agrega tras crear esa tabla)
    default_category_id             BIGINT,         -- FK → supplier_categories.id

    status_id                       BIGINT          NOT NULL REFERENCES statuses(id),

    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_suppliers_business    ON suppliers (business_id);
CREATE INDEX idx_suppliers_is_partner  ON suppliers (is_partner);
CREATE INDEX idx_suppliers_status      ON suppliers (status_id);

COMMENT ON TABLE  suppliers              IS 'Unifica partners (schema DBML) + suppliers (imagen). is_partner=true activa acceso a credit_facility.';
COMMENT ON COLUMN suppliers.is_partner  IS 'false=solo recibe pagos | true=accede a credit_facility. Reemplaza lógica de rol en tabla partners.';
COMMENT ON COLUMN suppliers.bank_account_number IS 'PII — cifrar con AES-256.';


-- -----------------------------------------------------------------------------
-- 6.1  supplier_categories  (antes: partner_categories)
-- -----------------------------------------------------------------------------
CREATE TABLE supplier_categories (
    id                          BIGSERIAL       PRIMARY KEY,
    external_id                 UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    supplier_id                 BIGINT          NOT NULL REFERENCES suppliers(id) ON DELETE CASCADE,
    name                        VARCHAR(100)    NOT NULL,
    discount_percentage         DECIMAL(5,4)    NOT NULL,
    interest_rate               DECIMAL(5,4)    NOT NULL,
    disbursement_fee_percent    DECIMAL(5,4),
    minimum_disbursement_fee    BIGINT,         -- En centavos de moneda local
    delay_days                  INT             NOT NULL,
    term_days                   INT             NOT NULL,
    status_id                   BIGINT          NOT NULL REFERENCES statuses(id),
    created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX idx_supplier_categories_supplier ON supplier_categories (supplier_id);

COMMENT ON TABLE supplier_categories IS 'Antes: partner_categories. Renombrada para alinearse con suppliers.';


-- -----------------------------------------------------------------------------
-- 6.2  sales_representatives  (depende de suppliers)
-- -----------------------------------------------------------------------------
CREATE TABLE sales_representatives (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    supplier_id     BIGINT          NOT NULL REFERENCES suppliers(id) ON DELETE CASCADE,
    user_id         BIGINT          REFERENCES users(id),
    name            VARCHAR(255)    NOT NULL,
    role            VARCHAR(100)    NOT NULL,
    status_id       BIGINT          NOT NULL REFERENCES statuses(id),
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_sales_rep_supplier ON sales_representatives (supplier_id);
CREATE INDEX idx_sales_rep_user     ON sales_representatives (user_id);

-- Ahora podemos agregar las FK diferidas de suppliers
ALTER TABLE suppliers
    ADD CONSTRAINT fk_suppliers_default_rep
        FOREIGN KEY (default_rep_id) REFERENCES sales_representatives(id) ON DELETE SET NULL,
    ADD CONSTRAINT fk_suppliers_default_category
        FOREIGN KEY (default_category_id) REFERENCES supplier_categories(id) ON DELETE SET NULL;


-- =============================================================================
-- BLOQUE 7: CREDIT_FACILITIES (antes: credit_applications_bnpl)
-- =============================================================================
-- TABLA COMPARATIVA DE FUSIÓN:
--   Schema DBML (credit_applications_bnpl)    →   Imagen (credit_facilities)   →   Resultado
--   id bigint PK                              →   id PK                        →   id BIGSERIAL PK
--   external_id uuid                          →   —                            →   external_id UUID
--   user_id bigint FK → users                 →   —                            →   user_id BIGINT FK
--   user_product_id bigint FK                 →   —                            →   user_product_id BIGINT FK
--   partner_id bigint FK → partners           →   —                            →   supplier_id BIGINT FK → suppliers ✓
--   partner_category_id bigint FK             →   —                            →   supplier_category_id BIGINT FK → supplier_categories ✓
--   sales_rep_id bigint FK                    →   —                            →   sales_rep_id BIGINT FK
--   business_id bigint FK                     →   FK business_id               →   business_id BIGINT FK → businesses
--   number_of_locations int                   →   —                            →   number_of_locations INT
--   number_of_employees int                   →   —                            →   number_of_employees INT
--   business_seniority_id bigint FK → options →   —                            →   business_seniority_id BIGINT FK → options
--   sector_experience varchar                 →   —                            →   sector_experience TEXT
--   business_flagship_m2 int                  →   —                            →   business_flagship_m2 INT
--   business_has_rent boolean                 →   —                            →   business_has_rent BOOLEAN
--   business_rent_amount bigint               →   —                            →   business_rent_amount BIGINT
--   monthly_income bigint                     →   —                            →   monthly_income BIGINT
--   monthly_expenses bigint                   →   —                            →   monthly_expenses BIGINT
--   monthly_purchases bigint                  →   —                            →   monthly_purchases BIGINT
--   current_purchases bigint                  →   —                            →   current_purchases BIGINT
--   total_assets bigint                       →   —                            →   total_assets BIGINT
--   requested_credit_line bigint              →   requested_amount (decimal)   →   requested_credit_line NUMERIC(18,2) ✓ (decimal > bigint para montos)
--   is_current_client boolean                 →   —                            →   is_current_client BOOLEAN
--   status_id bigint FK → statuses            →   status (varchar)             →   status_id BIGINT FK → statuses ✓
--   submission_date timestamptz               →   created_at                   →   submission_date TIMESTAMPTZ (más semántico)
--   approval_date timestamptz                 →   —                            →   approval_date TIMESTAMPTZ
--   rejection_reason varchar(500)             →   —                            →   rejection_reason VARCHAR(500)
--   credit_study_date timestamptz             →   —                            →   credit_study_date TIMESTAMPTZ
--   credit_score decimal(8,2)                 →   —                            →   credit_score DECIMAL(8,2)
--   credit_decision varchar                   →   —                            →   credit_decision VARCHAR(50)
--   approved_credit_line bigint               →   —                            →   approved_credit_line NUMERIC(18,2) ✓ decimal para montos
--   analyst_report text                       →   —                            →   analyst_report TEXT
--   risk_profile varchar                      →   —                            →   risk_profile VARCHAR(50)
--   privacy_policy_accepted boolean           →   —                            →   privacy_policy_accepted BOOLEAN
--   privacy_policy_date timestamptz           →   —                            →   privacy_policy_accepted_at TIMESTAMPTZ ✓ (nombre más claro)
--   product_type varchar                      →   product_type (imagen)        →   product_type VARCHAR(50) [BNPL | installment | open_credit]
--   —                                         →   total_limit (decimal)        →   total_limit NUMERIC(18,2) [NUEVO — límite aprobado total]
--   —                                         →   available_balance (decimal)  →   available_balance NUMERIC(18,2) [NUEVO — saldo disponible]
--   —                                         →   contract_signed_at           →   contract_signed_at TIMESTAMPTZ [NUEVO]
--   —                                         →   expires_at                   →   expires_at TIMESTAMPTZ [NUEVO — vencimiento de la facility]
-- =============================================================================

CREATE TABLE credit_facilities (
    id                          BIGSERIAL       PRIMARY KEY,
    external_id                 UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),

    -- Relaciones principales
    user_id                     BIGINT          NOT NULL REFERENCES users(id),
    business_id                 BIGINT          NOT NULL REFERENCES businesses(id),
    user_product_id             BIGINT          REFERENCES user_products(id),   -- FK agregada tras crear user_products
    supplier_id                 BIGINT          REFERENCES suppliers(id),       -- antes: partner_id
    supplier_category_id        BIGINT          REFERENCES supplier_categories(id),  -- antes: partner_category_id
    sales_rep_id                BIGINT          REFERENCES sales_representatives(id),

    -- Tipo de producto (antes disperso)
    product_type                VARCHAR(50)     NOT NULL
                                    CHECK (product_type IN ('bnpl', 'installment', 'open_credit')),

    -- Snapshot del negocio al momento de la solicitud
    number_of_locations         INT             CHECK (number_of_locations >= 0),
    number_of_employees         INT             CHECK (number_of_employees >= 0),
    business_seniority_id       BIGINT          REFERENCES options(id),
    sector_experience           TEXT,
    business_flagship_m2        INT             CHECK (business_flagship_m2 IS NULL OR business_flagship_m2 >= 1),
    business_has_rent           BOOLEAN,
    business_rent_amount        NUMERIC(18,2)   CHECK (business_rent_amount IS NULL OR business_rent_amount >= 0),

    -- Snapshot financiero al momento de la solicitud
    monthly_income              NUMERIC(18,2),
    monthly_expenses            NUMERIC(18,2),
    monthly_purchases           NUMERIC(18,2),  -- solo si is_current_client = true
    current_purchases           NUMERIC(18,2),  -- solo si is_current_client = false
    total_assets                NUMERIC(18,2),
    is_current_client           BOOLEAN         DEFAULT FALSE,

    -- Solicitud de crédito
    requested_credit_line       NUMERIC(18,2),  -- antes: bigint → numeric para centavos/decimales

    -- Decisión crediticia
    credit_study_date           TIMESTAMPTZ,
    credit_score                DECIMAL(8,2),
    credit_decision             VARCHAR(50),
    approved_credit_line        NUMERIC(18,2)   CHECK (approved_credit_line IS NULL OR approved_credit_line >= 0),
    analyst_report              TEXT,
    risk_profile                VARCHAR(50),

    -- Límites operativos de la facility (de la imagen)
    total_limit                 NUMERIC(18,2),  -- Límite total otorgado
    available_balance           NUMERIC(18,2),  -- Saldo disponible en tiempo real

    -- Fechas del ciclo de vida
    submission_date             TIMESTAMPTZ,
    approval_date               TIMESTAMPTZ,
    contract_signed_at          TIMESTAMPTZ,    -- NUEVO: de imagen
    expires_at                  TIMESTAMPTZ,    -- NUEVO: de imagen

    -- Rechazo
    rejection_reason            VARCHAR(500),

    -- Privacidad y consentimiento
    privacy_policy_accepted     BOOLEAN         DEFAULT FALSE,
    privacy_policy_accepted_at  TIMESTAMPTZ,    -- renombrado: policy_date → accepted_at

    -- Estado
    status_id                   BIGINT          NOT NULL REFERENCES statuses(id),

    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),

    -- Restricción: business_rent_amount solo si business_has_rent = true
    CONSTRAINT chk_facility_rent_amount
        CHECK (
            (business_has_rent = TRUE AND business_rent_amount IS NOT NULL)
            OR (business_has_rent = FALSE OR business_has_rent IS NULL)
        ),

    -- Restricción: available_balance <= total_limit
    CONSTRAINT chk_facility_balance_limit
        CHECK (available_balance IS NULL OR total_limit IS NULL OR available_balance <= total_limit)
);

-- Índices de acceso frecuente
CREATE INDEX idx_cf_user            ON credit_facilities (user_id);
CREATE INDEX idx_cf_business        ON credit_facilities (business_id);
CREATE INDEX idx_cf_supplier        ON credit_facilities (supplier_id);
CREATE INDEX idx_cf_status          ON credit_facilities (status_id);
CREATE INDEX idx_cf_product_type    ON credit_facilities (product_type);
CREATE INDEX idx_cf_submission_date ON credit_facilities (submission_date DESC);
-- Índice parcial para facilities activas (hot path)
CREATE INDEX idx_cf_active          ON credit_facilities (business_id, available_balance)
    WHERE status_id IN (SELECT id FROM statuses WHERE entity_type = 'credit_facilities' AND code = 'active');

COMMENT ON TABLE  credit_facilities IS 'Tabla central. Fusiona credit_applications_bnpl (schema) + credit_facilities (imagen). Gestiona el ciclo completo de una línea de crédito.';
COMMENT ON COLUMN credit_facilities.product_type IS 'bnpl | installment | open_credit';
COMMENT ON COLUMN credit_facilities.supplier_id  IS 'FK a suppliers. Antes: partner_id → partners.';
COMMENT ON COLUMN credit_facilities.total_limit  IS 'Límite total aprobado. De la imagen (credit_facilities central).';
COMMENT ON COLUMN credit_facilities.available_balance IS 'Saldo disponible. Se actualiza con cada desembolso y repago.';


-- =============================================================================
-- BLOQUE 8: ANÁLISIS AI
-- =============================================================================

CREATE TABLE ai_agent_analysis (
    id                          BIGSERIAL       PRIMARY KEY,
    external_id                 UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    facility_id                 BIGINT          NOT NULL REFERENCES credit_facilities(id),  -- antes: application_id
    html_url_agent_analysis     TEXT,
    json_agent_analysis         JSONB,
    agent_analysis_at           TIMESTAMPTZ,    -- renombrado: agent_analysis_timestamptz → agent_analysis_at
    agent_recommended_loc       BIGINT,
    agent_recommendation        BIGINT,         -- corregido typo: agent_recomendation → agent_recommendation
    created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX idx_ai_analysis_facility ON ai_agent_analysis (facility_id);
CREATE INDEX idx_ai_analysis_json ON ai_agent_analysis USING gin (json_agent_analysis);

COMMENT ON COLUMN ai_agent_analysis.facility_id IS 'Antes: application_id → credit_applications_bnpl.id. Ahora → credit_facilities.id.';


-- =============================================================================
-- BLOQUE 9: CONTRATOS Y FIRMAS
-- =============================================================================

CREATE TABLE contracts (
    id                  BIGSERIAL       PRIMARY KEY,
    external_id         UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    user_id             BIGINT          NOT NULL REFERENCES users(id),
    facility_id         BIGINT          REFERENCES credit_facilities(id),  -- antes: application_id
    zapsign_token       VARCHAR(255)    UNIQUE,
    status_id           BIGINT          NOT NULL REFERENCES statuses(id),
    original_file_url   TEXT,
    signed_file_url     TEXT,
    form_answers_json   JSONB,
    created_at          TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at          TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_contracts_facility ON contracts (facility_id);
CREATE INDEX idx_contracts_user     ON contracts (user_id);


CREATE TABLE contract_signers (
    id                      BIGSERIAL       PRIMARY KEY,
    external_id             UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    contract_id             BIGINT          REFERENCES contracts(id) ON DELETE CASCADE,
    person_id               BIGINT          REFERENCES persons(id),
    zapsign_signer_token    VARCHAR(255),
    status_id               BIGINT          NOT NULL REFERENCES statuses(id),
    sign_url                TEXT,
    ip_address              VARCHAR(45),
    geo_latitude            DECIMAL(10,7),  -- antes varchar → decimal para geolocalización
    geo_longitude           DECIMAL(10,7),  -- antes varchar → decimal para geolocalización
    signed_at               TIMESTAMPTZ,
    document_photo_url      TEXT,           -- PII — URL a almacenamiento cifrado
    document_verse_photo_url TEXT,          -- PII
    selfie_photo_url        TEXT,           -- PII — Biometría
    signature_image_url     TEXT,
    created_at              TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at              TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_contract_signers_contract ON contract_signers (contract_id);
CREATE INDEX idx_contract_signers_person   ON contract_signers (person_id);

COMMENT ON COLUMN contract_signers.geo_latitude  IS 'Cambiado de VARCHAR a DECIMAL(10,7) para integridad geoespacial.';
COMMENT ON COLUMN contract_signers.selfie_photo_url IS 'PII biométrico — URL debe apuntar a bucket cifrado con acceso temporal (presigned URLs).';


-- =============================================================================
-- BLOQUE 10: GARANTÍAS
-- =============================================================================

CREATE TABLE guarantors (
    id                          BIGSERIAL       PRIMARY KEY,
    external_id                 UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    facility_id                 BIGINT          NOT NULL REFERENCES credit_facilities(id),  -- antes: credit_application_id
    person_id                   BIGINT          NOT NULL REFERENCES persons(id),
    contract_signer_id          BIGINT          REFERENCES contract_signers(id),
    guarantor_type              VARCHAR(20)     NOT NULL,
    relationship_to_applicant   VARCHAR(100),
    is_primary_guarantor        BOOLEAN         DEFAULT FALSE,
    selected_after_credit_check BOOLEAN         DEFAULT FALSE,
    signature_url               TEXT,
    signature_date              TIMESTAMPTZ,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX idx_guarantors_facility ON guarantors (facility_id);
CREATE INDEX idx_guarantors_person   ON guarantors (person_id);


-- =============================================================================
-- BLOQUE 11: PORTAFOLIO DE PRODUCTOS
-- =============================================================================

CREATE TABLE user_products (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    user_id         BIGINT          NOT NULL REFERENCES users(id),
    product_type    VARCHAR(50)     NOT NULL,
    activated_at    TIMESTAMPTZ     NOT NULL,
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_user_products_user ON user_products (user_id);

-- Agregar FK diferida a credit_facilities (creada antes de user_products)
ALTER TABLE credit_facilities
    ADD CONSTRAINT fk_cf_user_product
        FOREIGN KEY (user_product_id) REFERENCES user_products(id) ON DELETE SET NULL;


CREATE TABLE product_bnpl (
    id                          BIGSERIAL       PRIMARY KEY,
    external_id                 UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    user_product_id             BIGINT          NOT NULL UNIQUE REFERENCES user_products(id),
    credit_limit                NUMERIC(18,2)   NOT NULL CHECK (credit_limit >= 0),
    available_credit_limit      NUMERIC(18,2)   NOT NULL CHECK (available_credit_limit >= 0),
    status_id                   BIGINT          NOT NULL REFERENCES statuses(id),
    has_active_payment_plan     BOOLEAN         DEFAULT FALSE,
    notification_channels       TEXT[],
    created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT now(),

    CONSTRAINT chk_bnpl_available_limit
        CHECK (available_credit_limit <= credit_limit)
);


CREATE TABLE bnpl_categories (
    id              BIGSERIAL   PRIMARY KEY,
    external_id     UUID        NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    product_bnpl_id BIGINT      REFERENCES product_bnpl(id) ON DELETE CASCADE,
    category_id     BIGINT      REFERENCES supplier_categories(id),   -- antes: partner_categories.id
    created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT now()
);


-- =============================================================================
-- BLOQUE 12: OPERACIONES FINANCIERAS
-- =============================================================================

-- -----------------------------------------------------------------------------
-- 12.1  purchase_orders  (de la imagen — nueva tabla)
-- -----------------------------------------------------------------------------
CREATE TABLE purchase_orders (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    loan_id         BIGINT          NOT NULL,   -- FK → loans (se agrega tras crear loans)
    facility_id     BIGINT          NOT NULL REFERENCES credit_facilities(id),
    supplier_id     BIGINT          REFERENCES suppliers(id),
    amount          NUMERIC(18,2)   NOT NULL CHECK (amount > 0),
    document_ref    VARCHAR(100),               -- Número de factura / referencia externa
    status_id       BIGINT          NOT NULL REFERENCES statuses(id),
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_purchase_orders_facility ON purchase_orders (facility_id);
CREATE INDEX idx_purchase_orders_supplier ON purchase_orders (supplier_id);


-- -----------------------------------------------------------------------------
-- 12.2  loans  (de la imagen)
-- -----------------------------------------------------------------------------
CREATE TABLE loans (
    id                  BIGSERIAL       PRIMARY KEY,
    external_id         UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    facility_id         BIGINT          NOT NULL REFERENCES credit_facilities(id),
    disbursement_type   VARCHAR(30)     NOT NULL
                            CHECK (disbursement_type IN ('bnpl', 'tap', 'installment', 'open_credit')),
    amount              NUMERIC(18,2)   NOT NULL CHECK (amount > 0),
    status_id           BIGINT          NOT NULL REFERENCES statuses(id),
    created_at          TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at          TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_loans_facility ON loans (facility_id);
CREATE INDEX idx_loans_status   ON loans (status_id);

-- Agregar FK diferida a purchase_orders
ALTER TABLE purchase_orders
    ADD CONSTRAINT fk_purchase_orders_loan
        FOREIGN KEY (loan_id) REFERENCES loans(id);

COMMENT ON COLUMN loans.disbursement_type IS 'bnpl | tap | installment | open_credit — corresponde a las anotaciones de la imagen.';


-- -----------------------------------------------------------------------------
-- 12.3  disbursements  (de la imagen)
-- -----------------------------------------------------------------------------
CREATE TABLE disbursements (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    loan_id         BIGINT          NOT NULL REFERENCES loans(id),
    supplier_id     BIGINT          NOT NULL REFERENCES suppliers(id),   -- antes: supplier_id en imagen
    amount          NUMERIC(18,2)   NOT NULL CHECK (amount > 0),
    transfer_ref    VARCHAR(100),
    disbursed_at    TIMESTAMPTZ,
    status_id       BIGINT          NOT NULL REFERENCES statuses(id),
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_disbursements_loan     ON disbursements (loan_id);
CREATE INDEX idx_disbursements_supplier ON disbursements (supplier_id);
CREATE INDEX idx_disbursements_date     ON disbursements (disbursed_at DESC);


-- -----------------------------------------------------------------------------
-- 12.4  repayments  (de la imagen)
-- -----------------------------------------------------------------------------
CREATE TABLE repayments (
    id              BIGSERIAL       PRIMARY KEY,
    external_id     UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    facility_id     BIGINT          NOT NULL REFERENCES credit_facilities(id),
    loan_id         BIGINT          REFERENCES loans(id),   -- Nullable: puede ser pago a nivel facility
    amount          NUMERIC(18,2)   NOT NULL CHECK (amount > 0),
    due_date        DATE            NOT NULL,
    paid_at         TIMESTAMPTZ,
    status_id       BIGINT          NOT NULL REFERENCES statuses(id),
    created_at      TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ     NOT NULL DEFAULT now()
);

CREATE INDEX idx_repayments_facility ON repayments (facility_id);
CREATE INDEX idx_repayments_loan     ON repayments (loan_id);
CREATE INDEX idx_repayments_due_date ON repayments (due_date);
-- Índice parcial: pagos pendientes (hot path de cobranza)
CREATE INDEX idx_repayments_pending ON repayments (due_date)
    WHERE paid_at IS NULL;

COMMENT ON COLUMN repayments.loan_id IS 'Nullable. Si es NULL, el repago aplica a nivel de facility (open_credit).';


-- =============================================================================
-- BLOQUE 13: PERFIL DE RIESGO
-- =============================================================================

CREATE TABLE risk_profiles (
    id                          BIGSERIAL       PRIMARY KEY,
    external_id                 UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    user_id                     BIGINT          NOT NULL REFERENCES users(id),
    user_product_id             BIGINT          NOT NULL REFERENCES user_products(id),
    risk_profile                VARCHAR(50),
    collection_priority_score   DECIMAL(8,4),
    payment_probability_score   DECIMAL(8,4),
    internal_score              DECIMAL(8,2),
    hybrid_score                DECIMAL(8,2),
    risk_ai_reasoning           TEXT,
    json_projections            JSONB,          -- corregido typo: json_proyections → json_projections
    json_weights                JSONB,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX idx_risk_profiles_user         ON risk_profiles (user_id);
CREATE INDEX idx_risk_profiles_user_product ON risk_profiles (user_product_id);
CREATE INDEX idx_risk_profiles_json         ON risk_profiles USING gin (json_projections);

COMMENT ON TABLE  risk_profiles IS 'Renombrada de risk_profile (singular) a risk_profiles (plural, convención estándar).';
COMMENT ON COLUMN risk_profiles.json_projections IS 'Corregido typo: json_proyections → json_projections.';


-- =============================================================================
-- BLOQUE 14: DOCUMENTACIÓN OPERATIVA
-- =============================================================================

CREATE TABLE documents (
    id                      BIGSERIAL       PRIMARY KEY,
    external_id             UUID            NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    person_id               BIGINT          REFERENCES persons(id),
    business_id             BIGINT          REFERENCES businesses(id),
    facility_id             BIGINT          REFERENCES credit_facilities(id),  -- antes: application_id
    document_type           VARCHAR(100)    NOT NULL,
    document_url            TEXT            NOT NULL,   -- PII — URL a bucket cifrado
    verification_status_id  BIGINT          NOT NULL REFERENCES statuses(id),
    upload_date             TIMESTAMPTZ     NOT NULL DEFAULT now(),
    created_at              TIMESTAMPTZ     NOT NULL DEFAULT now(),
    updated_at              TIMESTAMPTZ     NOT NULL DEFAULT now(),

    CONSTRAINT chk_documents_owner
        CHECK (person_id IS NOT NULL OR business_id IS NOT NULL OR facility_id IS NOT NULL)
);

CREATE INDEX idx_documents_person   ON documents (person_id) WHERE person_id IS NOT NULL;
CREATE INDEX idx_documents_business ON documents (business_id) WHERE business_id IS NOT NULL;
CREATE INDEX idx_documents_facility ON documents (facility_id) WHERE facility_id IS NOT NULL;

COMMENT ON COLUMN documents.document_url IS 'PII — debe apuntar a bucket S3/GCS con server-side encryption y presigned URLs de corta duración.';


CREATE TABLE credit_reports (
    id              BIGSERIAL   PRIMARY KEY,
    external_id     UUID        NOT NULL UNIQUE DEFAULT gen_random_uuid(),
    user_id         BIGINT      NOT NULL REFERENCES users(id),
    person_id       BIGINT      REFERENCES persons(id),
    business_id     BIGINT      REFERENCES businesses(id),
    facility_id     BIGINT      REFERENCES credit_facilities(id),   -- antes: application_id
    report_date     DATE        NOT NULL,
    bureau_name     VARCHAR(100),
    full_report_json JSONB,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX idx_credit_reports_user     ON credit_reports (user_id);
CREATE INDEX idx_credit_reports_facility ON credit_reports (facility_id);
CREATE INDEX idx_credit_reports_json     ON credit_reports USING gin (full_report_json);

COMMENT ON TABLE  credit_reports IS 'PII — full_report_json puede contener datos sensibles de burós de crédito. Revisar permisos de acceso.';


-- =============================================================================
-- BLOQUE 15: TRIGGER — updated_at automático
-- =============================================================================

CREATE OR REPLACE FUNCTION fn_set_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = now();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Aplicar trigger a todas las tablas con updated_at
DO $$
DECLARE
    t TEXT;
BEGIN
    FOREACH t IN ARRAY ARRAY[
        'statuses','options','roles','permissions','role_permissions',
        'users','currencies','cities','persons','businesses',
        'legal_representatives','shareholders',
        'suppliers','supplier_categories','sales_representatives',
        'credit_facilities','ai_agent_analysis',
        'contracts','contract_signers','guarantors',
        'user_products','product_bnpl','bnpl_categories',
        'purchase_orders','loans','disbursements','repayments',
        'risk_profiles','documents','credit_reports'
    ]
    LOOP
        EXECUTE format('
            CREATE TRIGGER trg_%s_updated_at
            BEFORE UPDATE ON %s
            FOR EACH ROW EXECUTE FUNCTION fn_set_updated_at();
        ', t, t);
    END LOOP;
END;
$$;


-- =============================================================================
-- BLOQUE 16: FUNCIÓN HELPER — Obtener status_id por entidad y código
-- =============================================================================

CREATE OR REPLACE FUNCTION get_status_id(p_entity_type TEXT, p_code TEXT)
RETURNS BIGINT AS $$
    SELECT id FROM statuses
    WHERE entity_type = p_entity_type AND code = p_code AND is_active = TRUE
    LIMIT 1;
$$ LANGUAGE sql STABLE;

COMMENT ON FUNCTION get_status_id IS 'Helper para obtener status_id por nombre de entidad y código. Usado en DEFAULT de columnas.';

-- =============================================================================
-- FIN DEL DDL
