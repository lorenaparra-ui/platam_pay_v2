// =============================================================================
// PLATAM PAY v2 — DBML alineado a libs/ (TypeORM)
// Versión: 2.0 | Fecha: 2026-04-09
// Fuente de verdad: entidades en libs/*-data/src + migraciones database/src/migrations
// Motor: PostgreSQL 15+ | Extensión: pgcrypto (donde aplique)
//
// SCHEMAS:
//   transversal_schema  → RBAC por partner, personas, ciudades, catálogo catalog_status_types, auditoría, params
//   suppliers_schema    → Negocios, partners, suppliers, SR, cuentas bancarias, órdenes, sagas
//   products_schema     → Crédito, contratos, categorías, consultas (Experian/SARLAFT/web/IA), loan_requests, usura
//   disbursement_schema → Préstamos placeholder, pagos, lotes, desembolsos, ajustes, causaciones
//   collections_schema  → Reglas de fee de cobranza
//
// NOTAS DE MODELO (libs vs DDL histórico):
//   - Catálogo de estados genéricos: tabla `catalog_status_types` (entidad StatusEntity en libs).
//   - ENUM nativos en columnas operativas: contracts.state, contract_templates.state, documents.verification_status,
//     partners.state, suppliers.state, sales_representatives.state, credit_applications.status, credit_facilities.state,
//     categories.state, etc. (ver @platam/shared).
//   - `transversal_schema.states` fue eliminada en migraciones de realineación; no hay entidad en libs.
//   - Roles (`roles`) están acotados a partner: `partner_id` NOT NULL (RoleEntity).
//   - `credit_facilities.business_id` → N:1 con businesses (varias líneas pueden compartir negocio).
//   - Tablas mínimas: disbursement_schema.loans, payments (solo id/external_id/timestamps hasta modelo de servicing).
// =============================================================================


// ─────────────────────────────────────────────────────────────────────────────
// SCHEMA: transversal_schema
// ─────────────────────────────────────────────────────────────────────────────

Table transversal_schema.catalog_status_types {
  id              bigint       [pk, note: 'BIGSERIAL / generated']
  external_id     uuid         [not null, unique, default: `gen_random_uuid()`]
  entity_type     varchar(100) [not null]
  code            varchar(50)  [not null]
  display_name    varchar(100) [not null]
  description     text
  is_active       boolean      [not null, default: true]
  created_at      timestamptz  [not null, default: `now()`]
  updated_at      timestamptz  [not null, default: `now()`]

  Indexes {
    (entity_type, code) [unique, name: 'uq_statuses_entity_code']
    entity_type         [name: 'idx_statuses_entity_type']
    external_id         [unique, name: 'idx_statuses_external_id']
  }

  Note: 'Entidad TypeORM: StatusEntity → tabla catalog_status_types. Catálogo paralelo a ENUMs operativos donde aplica.'
}

Table transversal_schema.roles {
  id          bigint       [pk]
  external_id uuid         [not null, unique, default: `gen_random_uuid()`]
  partner_id  bigint       [not null, ref: > suppliers_schema.partners.id, note: 'RoleEntity — rol por partner. Verificar columna en BD (puede faltar migración explícita).']
  name        varchar(80)  [not null, unique]
  description text
  created_at  timestamptz  [not null, default: `now()`]
  updated_at  timestamptz  [not null, default: `now()`]
}

Table transversal_schema.permissions {
  id          bigint       [pk]
  external_id uuid         [not null, unique, default: `gen_random_uuid()`]
  code        varchar(120) [not null, unique]
  description text
  created_at  timestamptz  [not null, default: `now()`]
  updated_at  timestamptz  [not null, default: `now()`]
}

Table transversal_schema.role_permissions {
  id            bigint      [pk]
  external_id   uuid        [not null, unique, default: `gen_random_uuid()`]
  role_id       bigint      [not null, ref: > transversal_schema.roles.id]
  permission_id bigint      [not null, ref: > transversal_schema.permissions.id]
  created_at    timestamptz [not null, default: `now()`]
  updated_at    timestamptz [not null, default: `now()`]

  Indexes {
    (role_id, permission_id) [unique]
  }
}

Table transversal_schema.currencies {
  id                  bigint      [pk]
  external_id         uuid        [not null, unique, default: `gen_random_uuid()`]
  code                varchar(3)  [not null, unique, note: 'ISO 4217']
  name                varchar(120) [not null]
  symbol              varchar(10)
  decimal_places      int         [not null, default: 2]
  thousand_separator  varchar(1)
  decimal_separator   varchar(1)
  is_active           boolean     [not null, default: true]
  created_at          timestamptz [not null, default: `now()`]
  updated_at          timestamptz [not null, default: `now()`]
}

Table transversal_schema.cities {
  id           bigint       [pk]
  external_id  uuid         [not null, unique, default: `gen_random_uuid()`]
  country_name varchar(120) [not null]
  country_code varchar(2)   [not null]
  state_name   varchar(120) [not null]
  state_code   varchar(3)
  city_name    varchar(120) [not null]
  currency_id  bigint       [not null, ref: > transversal_schema.currencies.id]
  created_at   timestamptz  [not null, default: `now()`]
  updated_at   timestamptz  [not null, default: `now()`]

  Indexes {
    (country_code, state_name, city_name) [unique]
  }
}

Table transversal_schema.users {
  id            bigint      [pk]
  external_id   uuid        [not null, unique, default: `gen_random_uuid()`]
  cognito_sub   uuid        [not null, unique]
  email         varchar(320) [not null, unique]
  role_id       bigint      [not null, ref: > transversal_schema.roles.id]
  state         varchar     [not null, default: 'active', note: 'ENUM transversal_schema.user_state']
  person_id     bigint      [not null, unique, ref: > transversal_schema.persons.id, note: 'UserEntity OneToOne person']
  last_login_at timestamptz
  created_at    timestamptz [not null, default: `now()`]
  updated_at    timestamptz [not null, default: `now()`]
}

Table transversal_schema.persons {
  id                   bigint       [pk]
  external_id          uuid         [not null, unique, default: `gen_random_uuid()`]
  first_name           varchar(255) [not null, note: 'PII']
  last_name            varchar(255) [not null, note: 'PII']
  doc_type             varchar      [not null, note: 'ENUM persons_doc_type_enum — DocTypes']
  doc_number           varchar      [not null, unique, note: 'PII']
  doc_issue_date       date
  birth_date           date
  gender               varchar(20)
  phone                varchar
  email                varchar(320) [unique, note: 'PII — nullable']
  residential_address  text         [note: 'PII']
  city_id              bigint       [not null, ref: > transversal_schema.cities.id]
  bank_account_id      bigint       [unique, ref: > suppliers_schema.bank_accounts.id, note: 'nullable en práctica; JoinColumn opcional']
  created_at           timestamptz  [not null, default: `now()`]
  updated_at           timestamptz  [not null, default: `now()`]

  Note: 'PersonEntity: sin business_address ni country_code a nivel columna. bank_account_id opcional (OneToOne).'
}

Table transversal_schema.upload_files_idempotency {
  id              bigint       [pk]
  idempotency_key varchar(512) [not null, unique]
  correlation_id  uuid         [not null]
  result          jsonb
  created_at      timestamptz  [not null, default: `now()`]
}

Table transversal_schema.partner_create_user_sqs_idempotency {
  id              bigint       [pk]
  idempotency_key varchar(512) [not null, unique]
  correlation_id  uuid         [not null]
  result          jsonb
  created_at      timestamptz  [not null, default: `now()`]
}

Table transversal_schema.global_params {
  id           bigint      [pk]
  external_id  uuid        [not null, unique]
  code         varchar(100) [not null]
  value        jsonb       [not null]
  description  text
  valid_from   date        [not null]
  created_by   bigint      [not null, ref: > transversal_schema.users.id]
  created_at   timestamptz [not null, default: `now()`]

  Indexes {
    (code, valid_from) [unique, name: 'UQ_global_params_code_valid_from']
  }
}

Table transversal_schema.audit_logs {
  id            bigint      [pk]
  external_id   uuid        [not null, unique]
  entity_type   varchar     [not null, note: 'ENUM audit_log_entity_type: loan|payment|loan_request']
  entity_id     bigint      [not null]
  action        varchar     [not null, note: 'ENUM audit_log_action_type']
  field_name    varchar(100)
  old_value     jsonb
  new_value     jsonb
  reason_code   varchar(100)
  notes         text
  performed_by  bigint      [not null, ref: > transversal_schema.users.id]
  performed_at  timestamptz [not null, default: `now()`]

  Indexes {
    (entity_type, entity_id) [name: 'IDX_audit_logs_entity_type_entity_id']
    performed_at             [name: 'IDX_audit_logs_performed_at']
  }
}


// ─────────────────────────────────────────────────────────────────────────────
// SCHEMA: suppliers_schema
// ─────────────────────────────────────────────────────────────────────────────

Table suppliers_schema.business_seniority {
  id          bigint       [pk]
  external_id uuid         [not null, unique, default: `gen_random_uuid()`]
  description varchar(100) [not null]
  range_start int          [not null]
  range_end   int          [not null]
  created_at  timestamptz  [not null, default: `now()`]
  updated_at  timestamptz  [not null, default: `now()`]
}

Table suppliers_schema.businesses {
  id                       bigint       [pk]
  external_id              uuid         [not null, unique, default: `gen_random_uuid()`]
  person_id                bigint       [not null, ref: > transversal_schema.persons.id]
  business_seniority_id    bigint       [ref: > suppliers_schema.business_seniority.id]
  city_id                  bigint       [ref: > transversal_schema.cities.id]
  entity_type              varchar(10)  [not null]
  business_name            varchar(255)
  business_address         text
  business_type            varchar(10)
  relationship_to_business varchar(100)
  legal_name               varchar(255)
  trade_name               varchar(255)
  tax_id                   varchar(50)  [unique]
  year_of_establishment    int
  created_at               timestamptz  [not null, default: `now()`]
  updated_at               timestamptz  [not null, default: `now()`]
}

Table suppliers_schema.legal_representatives {
  id          bigint      [pk]
  external_id uuid        [not null, unique, default: `gen_random_uuid()`]
  business_id bigint      [not null, ref: > suppliers_schema.businesses.id]
  person_id   bigint      [not null, ref: > transversal_schema.persons.id]
  is_primary  boolean     [not null, default: true]
  created_at  timestamptz [not null, default: `now()`]
  updated_at  timestamptz [not null, default: `now()`]
}

Table suppliers_schema.shareholders {
  id                       bigint       [pk]
  external_id              uuid         [not null, unique, default: `gen_random_uuid()`]
  business_id              bigint       [not null, ref: > suppliers_schema.businesses.id]
  person_id                bigint       [not null, ref: > transversal_schema.persons.id]
  ownership_percentage     decimal(5,4)
  evaluation_order         int
  credit_check_required    boolean      [not null, default: false]
  credit_check_completed   boolean      [not null, default: false]
  is_legal_representative  boolean      [not null, default: false]
  created_at               timestamptz  [not null, default: `now()`]
  updated_at               timestamptz  [not null, default: `now()`]
}

Table suppliers_schema.bank_accounts {
  id                 bigint       [pk]
  external_id        uuid         [not null, unique, default: `gen_random_uuid()`]
  bank_entity        varchar(255) [not null]
  account_number     varchar(500) [not null, note: 'PII — transformer cifrado']
  bank_certification text
  account_type       varchar      [not null, note: 'ENUM bank_account_account_type_enum: saving|checking']
  created_at         timestamptz  [not null, default: `now()`]
  updated_at         timestamptz  [not null, default: `now()`]
}

Table suppliers_schema.suppliers {
  id              bigint      [pk]
  external_id     uuid        [not null, unique, default: `gen_random_uuid()`]
  business_id     bigint      [not null, unique, ref: > suppliers_schema.businesses.id]
  bank_account_id bigint      [unique, ref: > suppliers_schema.bank_accounts.id]
  state           varchar     [not null, note: 'ENUM SupplierState active|inactive — ver migración / tipo PG']
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]

  Note: 'SupplierEntity: sin legal_representative_id. Partner 1:1 vía partners.supplier_id.'
}

Table suppliers_schema.partners {
  id                              bigint      [pk]
  external_id                     uuid        [not null, unique, default: `gen_random_uuid()`]
  business_id                     bigint      [not null, ref: > suppliers_schema.businesses.id]
  supplier_id                     bigint      [not null, unique, ref: > suppliers_schema.suppliers.id]
  alias                           varchar(100) [note: 'UNIQUE parcial WHERE alias IS NOT NULL (UQ_partners_alias)']
  acronym                         varchar(10)
  logo_url                        text
  co_branding_logo_url            text
  primary_color                   varchar(7)
  secondary_color                 varchar(7)
  light_color                     varchar(7)
  notification_email              varchar
  webhook_url                     text
  disbursement_notification_email varchar
  api_key_hash                    text
  send_sales_rep_voucher          boolean     [not null, default: false]
  country_code                    varchar(2)
  state                           varchar     [not null, default: 'active', note: 'ENUM partner_state']
  created_at                      timestamptz [not null, default: `now()`]
  updated_at                      timestamptz [not null, default: `now()`]

  Indexes {
    state        [name: 'IDX_partners_state']
    business_id  [name: 'IDX_partners_business_id']
  }
}

Table suppliers_schema.sales_representatives {
  id          bigint      [pk]
  external_id uuid        [not null, unique, default: `gen_random_uuid()`]
  partner_id  bigint      [not null, ref: > suppliers_schema.partners.id]
  user_id     bigint      [not null, unique, ref: > transversal_schema.users.id, note: 'OneToOne user']
  state       varchar     [not null, default: 'active', note: 'ENUM sales_representative_state (active|inactive)']
  is_default  boolean     [not null, default: false]
  created_at  timestamptz [not null, default: `now()`]
  updated_at  timestamptz [not null, default: `now()`]
}

Table suppliers_schema.purchase_orders {
  id           bigint        [pk]
  external_id  uuid          [not null, unique, default: `gen_random_uuid()`]
  user_id      varchar(255)  [not null, note: 'Identificador externo string; no FK a users.id']
  supplier_id  bigint        [not null, ref: > suppliers_schema.suppliers.id]
  amount       decimal(18,2) [not null]
  document_url text
  created_at   timestamptz   [not null, default: `now()`]
  updated_at   timestamptz   [not null, default: `now()`]
}

Table suppliers_schema.partner_onboarding_sagas {
  id                          bigint      [pk]
  external_id                 uuid        [not null, unique]
  correlation_id              uuid        [not null]
  status                      varchar(32) [not null]
  current_step                smallint    [not null, default: 0]
  credit_facility_external_id uuid
  user_external_id            uuid
  person_external_id          uuid
  business_external_id        uuid
  bank_account_external_id    uuid
  partner_external_id         uuid
  error_message               text
  created_at                  timestamptz [not null, default: `now()`]
  updated_at                  timestamptz [not null, default: `now()`]
}


// ─────────────────────────────────────────────────────────────────────────────
// SCHEMA: products_schema
// ─────────────────────────────────────────────────────────────────────────────

Table products_schema.contract_templates {
  id           bigint      [pk]
  external_id  uuid        [not null, unique, default: `gen_random_uuid()`]
  name         varchar(255) [not null]
  description  text
  template_url text        [not null]
  version      varchar(50)
  state        varchar     [not null, default: 'active', note: 'ENUM credit_facility_state — ContractTemplateCatalogStatus']
  created_at   timestamptz [not null, default: `now()`]
  updated_at   timestamptz [not null, default: `now()`]

  Note: 'ContractTemplateEntity (libs). El DDL histórico puede incluir template_family_id / category_id hasta una migración de recorte; la entidad actual es esta forma mínima.'
}

Table products_schema.contracts {
  id                   bigint      [pk]
  external_id          uuid        [not null, unique, default: `gen_random_uuid()`]
  user_id              bigint      [ref: > transversal_schema.users.id]
  contract_template_id bigint      [ref: > products_schema.contract_templates.id]
  zapsign_token        varchar     [unique]
  state                varchar     [not null, default: 'pending', note: 'ENUM contract_catalog_status']
  original_file_url    text
  signed_file_url      text
  form_answers_json    jsonb
  created_at           timestamptz [not null, default: `now()`]
  updated_at           timestamptz [not null, default: `now()`]
}

Table products_schema.credit_facilities {
  id           bigint        [pk]
  external_id  uuid          [not null, unique, default: `gen_random_uuid()`]
  contract_id  bigint        [ref: > products_schema.contracts.id, note: 'OneToOne opcional en entidad; índice no único en migraciones típicas']
  business_id  bigint        [not null, ref: > suppliers_schema.businesses.id, note: 'ManyToOne — N facilidades por negocio']
  state        varchar       [not null, default: 'active', note: 'ENUM credit_facility_state']
  total_limit  decimal(18,4) [not null]
  created_at   timestamptz   [not null, default: `now()`]
  updated_at   timestamptz   [not null, default: `now()`]

  Indexes {
    business_id [name: 'IDX_credit_facilities_business_id']
  }
}

Table products_schema.categories {
  id                       bigint        [pk]
  external_id              uuid          [not null, unique, default: `gen_random_uuid()`]
  credit_facility_id       bigint        [not null, ref: > products_schema.credit_facilities.id]
  partner_id               bigint        [ref: > suppliers_schema.partners.id]
  name                     varchar(255)  [not null]
  modality                 varchar       [not null, note: 'ENUM loan_request_modality bullet|cuotas']
  discount_percentage      decimal(8,4)  [not null]
  interest_rate            decimal(8,4)  [not null]
  disbursement_fee_percent decimal(8,4)
  minimum_disbursement_fee decimal(18,4)
  delay_days               int           [not null]
  term_days                int           [not null]
  installment_frequency    varchar       [not null, note: 'ENUM category_installment_frequency']
  installment_count        int           [not null]
  initial_payment_pct      decimal(8,4)  [not null]
  state                    varchar       [not null, default: 'active', note: 'ENUM credit_facility_state']
  created_at               timestamptz   [not null, default: `now()`]
  updated_at               timestamptz   [not null, default: `now()`]
}

Table products_schema.credit_applications {
  id                      bigint        [pk]
  external_id             uuid          [not null, unique, default: `gen_random_uuid()`]
  person_id               bigint        [ref: > transversal_schema.persons.id]
  partner_id              bigint        [ref: > suppliers_schema.partners.id]
  partner_category_id     bigint        [ref: > products_schema.categories.id]
  business_id             bigint        [ref: > suppliers_schema.businesses.id]
  sales_representative_id bigint        [ref: > suppliers_schema.sales_representatives.id]
  contract_id             bigint        [ref: > products_schema.contracts.id]
  number_of_locations     int
  number_of_employees     int
  business_seniority      varchar
  sector_experience       varchar
  business_flagship_m2    int
  business_has_rent       boolean
  business_rent_amount    bigint
  monthly_income          bigint
  monthly_expenses        bigint
  monthly_purchases       bigint
  current_purchases       bigint
  total_assets            bigint
  requested_credit_line   bigint
  is_current_client       boolean       [not null, default: false]
  status                  varchar       [not null, default: 'in_progress', note: 'ENUM credit_application_status']
  submission_date         timestamptz
  approval_date           timestamptz
  rejection_reason        varchar(500)
  credit_study_date       timestamptz
  credit_score            decimal(8,2)
  credit_decision         varchar
  approved_credit_line    bigint
  analyst_report          text
  risk_profile            varchar
  privacy_policy_accepted boolean       [not null, default: false]
  privacy_policy_date     timestamptz
  created_at              timestamptz   [not null, default: `now()`]
  updated_at              timestamptz   [not null, default: `now()`]

  Indexes {
    (partner_id, created_at) [name: 'IDX_credit_applications_partner_created_at']
    (person_id, created_at)  [name: 'IDX_credit_applications_person_created_at']
  }
}

Table products_schema.documents {
  id                    bigint       [pk]
  external_id           uuid         [not null, unique, default: `gen_random_uuid()`]
  document_type         varchar(100) [not null]
  document_url          text         [not null]
  verification_status   varchar      [note: 'ENUM document_verification_status nullable']
  credit_application_id bigint       [ref: > products_schema.credit_applications.id]
  created_at            timestamptz  [not null, default: `now()`]
  updated_at            timestamptz  [not null, default: `now()`]
}

Table products_schema.experian_queries {
  id                    bigint      [pk]
  external_id           uuid        [not null, unique]
  credit_application_id bigint      [not null, ref: > products_schema.credit_applications.id]
  person_id             bigint      [ref: > transversal_schema.persons.id]
  business_id           bigint      [ref: > suppliers_schema.businesses.id]
  query_type            varchar     [not null, note: 'ENUM experian_query_type']
  credit_report         jsonb
  credit_score          decimal(8,2)
  consulted_at          timestamptz [not null]
  status                varchar     [not null, default: 'pending', note: 'ENUM experian_query_status']
  error_message         text
  created_at            timestamptz [not null, default: `now()`]
  updated_at            timestamptz [not null, default: `now()`]

  Indexes {
    credit_application_id [name: 'IDX_experian_queries_credit_application_id']
  }
}

Table products_schema.sarlaft_checks {
  id                    bigint      [pk]
  external_id           uuid        [not null, unique]
  credit_application_id bigint      [not null, ref: > products_schema.credit_applications.id]
  person_id             bigint      [not null, ref: > transversal_schema.persons.id]
  business_id           bigint      [ref: > suppliers_schema.businesses.id]
  has_match             boolean     [not null]
  status                varchar     [not null, default: 'pending', note: 'ENUM sarlaft_check_status']
  consulted_at          timestamptz [not null]
  sources               jsonb
  detail                text
  created_at            timestamptz [not null, default: `now()`]
  updated_at            timestamptz [not null, default: `now()`]

  Indexes {
    credit_application_id [name: 'IDX_sarlaft_checks_credit_application_id']
  }
}

Table products_schema.web_queries {
  id                    bigint      [pk]
  external_id           uuid        [not null, unique]
  credit_application_id bigint      [not null, ref: > products_schema.credit_applications.id]
  query_type            varchar     [not null, note: 'ENUM web_query_type']
  person_id             bigint      [ref: > transversal_schema.persons.id]
  consulted_at          timestamptz [not null]
  query_result          jsonb
  created_at            timestamptz [not null, default: `now()`]
  updated_at            timestamptz [not null, default: `now()`]

  Indexes {
    credit_application_id [name: 'IDX_web_queries_credit_application_id']
  }
}

Table products_schema.ai_agent_analysis {
  id                    bigint      [pk]
  external_id           uuid        [not null, unique]
  credit_application_id bigint      [not null, unique, ref: > products_schema.credit_applications.id]
  analysis_result       jsonb       [not null]
  recommendation        varchar     [not null, note: 'ENUM ai_agent_analysis_recommendation']
  confidence_score      decimal(5,4)
  analyzed_at           timestamptz [not null]
  created_at            timestamptz [not null, default: `now()`]
  updated_at            timestamptz [not null, default: `now()`]
}

Table products_schema.loan_requests {
  id                        bigint      [pk]
  external_id               uuid        [not null, unique]
  credit_facility_id        bigint      [not null, ref: > products_schema.credit_facilities.id]
  category_id               bigint      [not null, ref: > products_schema.categories.id]
  partner_id                bigint      [ref: > suppliers_schema.partners.id]
  supplier_id               bigint      [ref: > suppliers_schema.suppliers.id]
  sales_representative_id   bigint      [ref: > suppliers_schema.sales_representatives.id]
  product_type              varchar     [not null, note: 'ENUM loan_request_product_type']
  loan_modality             varchar     [not null, note: 'ENUM loan_request_modality']
  channel                   varchar     [not null, note: 'ENUM loan_request_channel']
  order_reference           varchar(255)
  requested_amount          decimal(18,4) [not null]
  confirmed_amount          decimal(18,4)
  installment_count         int
  initial_payment_amount    decimal(18,4)
  initial_payment_paid      boolean     [not null, default: false]
  requires_client_approval  boolean     [not null, default: false]
  client_approved_at        timestamptz
  client_rejection_reason   text
  partner_confirmed_at      timestamptz
  partner_rejection_reason  text
  invoice_url               text
  notes                     text[]      [note: 'PostgreSQL text[]']
  status                    varchar     [not null, default: 'draft', note: 'ENUM loan_request_status']
  created_at                timestamptz [not null, default: `now()`]
  updated_at                timestamptz [not null, default: `now()`]

  Indexes {
    credit_facility_id [name: 'IDX_loan_requests_credit_facility_id']
    status             [name: 'IDX_loan_requests_status']
    partner_id         [name: 'IDX_loan_requests_partner_id']
  }
}

Table products_schema.usura_rates {
  id           bigint      [pk]
  external_id  uuid        [not null, unique]
  category     varchar     [not null, note: 'ENUM usura_rate_type']
  rate_ea      decimal(8,6) [not null]
  valid_from   date        [not null]
  resolution   varchar(100)
  created_by   bigint      [not null, ref: > transversal_schema.users.id]
  created_at   timestamptz [not null, default: `now()`]

  Indexes {
    (category, valid_from) [unique, name: 'UQ_usura_rates_category_valid_from']
  }
}


// ─────────────────────────────────────────────────────────────────────────────
// SCHEMA: disbursement_schema
// ─────────────────────────────────────────────────────────────────────────────

Table disbursement_schema.loans {
  id          bigint      [pk]
  external_id uuid        [not null, unique]
  created_at  timestamptz [not null, default: `now()`]
  updated_at  timestamptz [not null, default: `now()`]

  Note: 'LoanEntity mínima — ampliar cuando exista modelo de préstamo.'
}

Table disbursement_schema.payments {
  id          bigint      [pk]
  external_id uuid        [not null, unique]
  created_at  timestamptz [not null, default: `now()`]
  updated_at  timestamptz [not null, default: `now()`]

  Note: 'PaymentEntity mínima.'
}

Table disbursement_schema.disbursement_batches {
  id                  bigint      [pk]
  external_id         uuid        [not null, unique]
  disbursement_type   varchar     [not null, note: 'ENUM disbursement_type']
  partner_id          bigint      [not null, ref: > suppliers_schema.partners.id]
  batch_type          varchar     [not null, note: 'ENUM batch_type']
  gross_amount        decimal(18,4) [not null, default: 0]
  adjustments_amount  decimal(18,4) [not null, default: 0]
  net_amount          decimal(18,4) [not null, default: 0]
  total_count         int         [not null, default: 0]
  success_count       int         [not null, default: 0]
  failed_count        int         [not null, default: 0]
  file_url            text
  response_file_url   text
  voucher_url         text
  disbursed_at        date
  generated_by        bigint      [not null, ref: > transversal_schema.users.id]
  status              varchar     [not null, default: 'pending', note: 'ENUM disbursement_batches_status']
  created_at          timestamptz [not null, default: `now()`]
  updated_at          timestamptz [not null, default: `now()`]
}

Table disbursement_schema.adjustments {
  id                     bigint      [pk]
  external_id            uuid        [not null, unique]
  loan_id                bigint      [not null, ref: > disbursement_schema.loans.id]
  partner_id             bigint      [not null, ref: > suppliers_schema.partners.id]
  disbursement_batch_id  bigint      [ref: > disbursement_schema.disbursement_batches.id]
  adjustment_type        varchar     [not null, note: 'ENUM adjustments_type']
  amount                 decimal(18,4) [not null]
  event_date             date        [not null]
  affects_loan_balance   boolean     [not null, default: false]
  notes                  text[]
  status                 varchar     [not null, default: 'pending', note: 'ENUM adjustments_status']
  applied_at             timestamptz
  created_by             bigint      [not null, ref: > transversal_schema.users.id]
  created_at             timestamptz [not null, default: `now()`]
  updated_at             timestamptz [not null, default: `now()`]
}

Table disbursement_schema.payment_allocations {
  id                         bigint      [pk]
  external_id                uuid        [not null, unique]
  payment_id                 bigint      [not null, ref: > disbursement_schema.payments.id]
  loan_id                    bigint      [not null, ref: > disbursement_schema.loans.id]
  allocated_amount           decimal(18,4) [not null]
  principal_allocated        decimal(18,4) [not null, default: 0]
  current_interest_allocated decimal(18,4) [not null, default: 0]
  overdue_interest_allocated decimal(18,4) [not null, default: 0]
  mora_interest_allocated    decimal(18,4) [not null, default: 0]
  fees_allocated             decimal(18,4) [not null, default: 0]
  iva_allocated              decimal(18,4) [not null, default: 0]
  loan_status_after          varchar(15) [not null]
  created_at                 timestamptz [not null, default: `now()`]

  Indexes {
    payment_id [name: 'IDX_payment_allocations_payment_id']
    loan_id    [name: 'IDX_payment_allocations_loan_id']
  }
}

Table disbursement_schema.disbursements {
  id                 bigint      [pk]
  external_id        uuid        [not null, unique]
  disbursement_type  varchar     [not null, note: 'ENUM disbursement_type']
  loan_id            bigint      [ref: > disbursement_schema.loans.id]
  loan_request_id    bigint      [ref: > products_schema.loan_requests.id]
  partner_id         bigint      [ref: > suppliers_schema.partners.id]
  supplier_id        bigint      [ref: > suppliers_schema.suppliers.id]
  bank_account_id    bigint      [not null, ref: > suppliers_schema.bank_accounts.id]
  amount             decimal(18,4) [not null]
  batch_id           bigint      [ref: > disbursement_schema.disbursement_batches.id]
  status             varchar     [not null, default: 'pending', note: 'ENUM disbursement_status']
  disbursed_at       timestamptz
  failure_reason     text
  voucher_url        text
  created_at         timestamptz [not null, default: `now()`]
  updated_at         timestamptz [not null, default: `now()`]

  Indexes {
    batch_id  [name: 'idx_disbursements_batch_id']
    loan_id   [name: 'idx_disbursements_loan_id']
    status    [name: 'idx_disbursements_status']
  }
}

Table disbursement_schema.accruals {
  id                         bigint      [pk]
  loan_id                    bigint      [not null, ref: > disbursement_schema.loans.id]
  calculation_date           date        [not null]
  balance_principal_overdue  decimal(18,4) [not null, default: 0]
  daily_interest_current     decimal(18,4) [not null, default: 0]
  daily_interest_mora        decimal(18,4) [not null, default: 0]
  daily_fees                 decimal(18,4) [not null, default: 0]
  status_after               varchar(15) [not null]
  created_at                 timestamptz [not null, default: `now()`]

  Indexes {
    (loan_id, calculation_date) [unique, name: 'UQ_accruals_loan_id_calculation_date']
    calculation_date            [name: 'IDX_accruals_calculation_date']
  }
}


// ─────────────────────────────────────────────────────────────────────────────
// SCHEMA: collections_schema
// ─────────────────────────────────────────────────────────────────────────────

Table collections_schema.collection_fee_rules {
  id           bigint      [pk]
  external_id  uuid        [not null, unique]
  days_overdue int         [not null]
  fee_rate     decimal(8,6) [not null]
  valid_from   date        [not null]
  created_by   bigint      [not null, ref: > transversal_schema.users.id]
  created_at   timestamptz [not null, default: `now()`]

  Indexes {
    (days_overdue, valid_from) [unique, name: 'UQ_collection_fee_rules_days_overdue_valid_from']
  }
}


// ─────────────────────────────────────────────────────────────────────────────
// REF (resumen FK cross-schema — redundante con ref: > en columnas)
// ─────────────────────────────────────────────────────────────────────────────

Ref: transversal_schema.roles.partner_id > suppliers_schema.partners.id
Ref: transversal_schema.users.person_id > transversal_schema.persons.id
Ref: transversal_schema.persons.bank_account_id > suppliers_schema.bank_accounts.id
