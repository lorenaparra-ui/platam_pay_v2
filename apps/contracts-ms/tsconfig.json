{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/contracts-ms",
    "baseUrl": ".",
    "paths": {
      "@config/*": ["src/config/*"],
      "@common/*": ["src/common/*"],
      "@messaging/*": ["src/modules/messaging/*"],
      "@modules/*": ["src/modules/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@app/products-data": ["../../libs/products-data/src"],
      "@platam/shared": ["../../libs/shared/src"]
